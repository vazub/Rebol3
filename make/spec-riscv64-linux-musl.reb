		%core/p-checksum.c
		%core/p-console.c
		%core/p-crypt.c
		%core/p-dir.c
		%core/p-dns.c
		%core/p-event.c
		%core/p-file.c
		%core/p-net.c
		%core/s-cases.c
		%core/s-crc.c
		%core/s-file.c
		%core/s-find.c
		%core/s-make.c
		%core/s-mold.c
