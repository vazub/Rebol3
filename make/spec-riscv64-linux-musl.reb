	host-files: [
		%os/dev-dns.c
		%os/dev-net.c
		%os/host-args.c
		%os/host-device.c
		%os/host-stdio.c
		%os/posix/dev-event.c
		%os/posix/dev-file.c
		%os/posix/dev-stdio.c
		%os/posix/host-lib.c
		%os/posix/host-readline.c
	]
	;NOTE: don't sort, the following file order is crucial
	mezz-base-files: [
		%mezz/base-constants.reb
		%mezz/base-funcs.reb
		%mezz/base-series.reb
		%mezz/base-files.reb
		%mezz/base-debug.reb
		%mezz/base-defs.reb
		%mezz/base-collected.reb
	]
	mezz-sys-files: [
		%mezz/sys-base.reb
		%mezz/sys-codec.reb
		%mezz/sys-load.reb
		%mezz/sys-ports.reb
		%mezz/sys-start.reb
	]
	;NOTE: don't sort, the following file order is crucial
	mezz-lib-files: [
		%mezz/mezz-ansi.reb
		%mezz/mezz-secure.reb
		%mezz/mezz-types.reb
		%mezz/mezz-func.reb
		%mezz/mezz-debug.reb
		%mezz/mezz-logger.reb
		%mezz/mezz-control.reb
		%mezz/mezz-save.reb
		%mezz/mezz-series.reb
		%mezz/mezz-files.reb
		%mezz/mezz-shell.reb
		%mezz/mezz-math.reb
		%mezz/mezz-help.reb
		%mezz/mezz-banner.reb
		%mezz/mezz-tail.reb
		%mezz/prot-mail.reb
		%mezz/codec-mime-field.reb
		%mezz/codec-mime-types.reb
		%mezz/codec-quoted-printable.reb
		%mezz/codec-pkix.reb
		%mezz/codec-ppk.reb
		%mezz/codec-ssh-key.reb
		%mezz/codec-safe.reb
		%mezz/codec-utc-time.reb
		%mezz/codec-der.reb
		%mezz/codec-crt.reb
		%mezz/codec-unixtime.reb
		%mezz/codec-ar.reb
		%mezz/codec-gzip.reb
		%mezz/codec-zip.reb
		%mezz/codec-tar.reb
		%mezz/codec-json.reb
		%mezz/mezz-date.reb
	]
	mezz-prot-files: [
		%mezz/prot-http.reb
		%mezz/prot-pop3.reb
		%mezz/prot-smtp.reb
		%mezz/prot-tls.reb
	]
	boot-host-files: []
	config: [
		COLOR_CONSOLE
		DEBUG_HASH_COLLISIONS
		INCLUDE_CRYPTOGRAPHY
		INCLUDE_DEFLATE
		INCLUDE_MBEDTLS
		INCLUDE_RSA
		INCLUDE_SHA224
		INCLUDE_SHA384
		INCLUDE_TASK
		INCLUDE_XXHASH
		MBEDTLS_AES_C
		MBEDTLS_AESNI_C
		MBEDTLS_BIGNUM_C
		MBEDTLS_CTR_DRBG_C
		MBEDTLS_DHM_C
		MBEDTLS_ECDH_C
		MBEDTLS_ECDSA_C
		MBEDTLS_ECP_C
		MBEDTLS_ECP_DP_CURVE25519_ENABLED
		MBEDTLS_ECP_DP_CURVE448_ENABLED
		MBEDTLS_ECP_DP_SECP192R1_ENABLED
		MBEDTLS_ECP_DP_SECP224R1_ENABLED
		MBEDTLS_ECP_DP_SECP256R1_ENABLED
		MBEDTLS_ECP_DP_SECP384R1_ENABLED
		MBEDTLS_ECP_DP_SECP521R1_ENABLED
		MBEDTLS_ENTROPY_C
		MBEDTLS_GCM_C
		MBEDTLS_OID_C
		MBEDTLS_PKCS1_V15
		MBEDTLS_PKCS1_V21
	]
]
